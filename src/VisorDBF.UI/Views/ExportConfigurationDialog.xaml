<Window x:Class="VisorDBF.UI.Views.ExportConfigurationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Configuracion de exportacion"
        Width="500" Height="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFF"
        FontFamily="Segoe UI"
        KeyboardNavigation.TabNavigation="Cycle">

    <DockPanel>
        <!-- Perfiles (Top dock) -->
        <Border DockPanel.Dock="Top" Background="#F5F5F5" Padding="12,8" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Perfil:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Profiles}"
                          SelectedItem="{Binding SelectedProfile}"
                          DisplayMemberPath="Name"
                          MinWidth="160"
                          VerticalAlignment="Center"/>
                <Button Grid.Column="2" Content="Guardar como..."
                        Command="{Binding SaveAsProfileCommand}"
                        Margin="4,0,0,0" Padding="8,2"/>
                <Button Grid.Column="3" Content="Renombrar"
                        Command="{Binding RenameProfileCommand}"
                        Margin="4,0,0,0" Padding="8,2"/>
                <Button Grid.Column="4" Content="Eliminar"
                        Command="{Binding DeleteProfileCommand}"
                        Margin="4,0,0,0" Padding="8,2"/>
            </Grid>
        </Border>

        <!-- Botones (Bottom dock) -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="16,8,16,16">
            <Button x:Name="BtnAceptar"
                    Content="Aceptar"
                    IsDefault="True"
                    Click="BtnAceptar_Click"
                    Width="88" Height="30"
                    Margin="0,0,8,0"
                    ToolTip="Guardar la configuracion y cerrar"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button x:Name="BtnAplicar"
                    Content="Aplicar"
                    Command="{Binding ApplyCommand}"
                    Width="88" Height="30"
                    Margin="0,0,8,0"
                    ToolTip="Guardar la configuracion sin cerrar"
                    Style="{StaticResource SecondaryButtonStyle}"/>
            <Button x:Name="BtnCancelar"
                    Content="Cancelar"
                    IsCancel="True"
                    Click="BtnCancelar_Click"
                    Width="88" Height="30"
                    ToolTip="Descartar los cambios y cerrar"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>

        <!-- Contenido scrollable -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,16,16,0">

                <!-- GroupBox: Separadores -->
                <GroupBox Header="Separadores" Margin="0,0,0,12">
                    <StackPanel Margin="8">
                            <TextBlock Text="Separador de columnas:" FontSize="11" Foreground="#5E5E5E" Margin="0,0,0,6"/>
                        <RadioButton Content="Coma  (,)" GroupName="ColSep" Margin="0,0,0,2">
                            <RadioButton.IsChecked>
                                <Binding Path="ColumnSeparator" Converter="{StaticResource StringEqualsConverter}" ConverterParameter=","/>
                            </RadioButton.IsChecked>
                        </RadioButton>
                        <RadioButton Content="Punto y coma  (;)" GroupName="ColSep" Margin="0,0,0,2">
                            <RadioButton.IsChecked>
                                <Binding Path="ColumnSeparator" Converter="{StaticResource StringEqualsConverter}" ConverterParameter=";"/>
                            </RadioButton.IsChecked>
                        </RadioButton>
                        <RadioButton Content="Tabulador  (\t)" GroupName="ColSep" Margin="0,0,0,2">
                            <RadioButton.IsChecked>
                                <Binding Path="ColumnSeparator" Converter="{StaticResource StringEqualsConverter}" ConverterParameter="	"/>
                            </RadioButton.IsChecked>
                        </RadioButton>
                        <RadioButton Content="Pipe  (|)" GroupName="ColSep" Margin="0,0,0,2">
                            <RadioButton.IsChecked>
                                <Binding Path="ColumnSeparator" Converter="{StaticResource StringEqualsConverter}" ConverterParameter="|"/>
                            </RadioButton.IsChecked>
                        </RadioButton>
                        <DockPanel Margin="0,4,0,0">
                            <RadioButton Content="Personalizado" GroupName="ColSep"
                                         IsChecked="{Binding UseCustomSeparator}" DockPanel.Dock="Left"/>
                            <TextBox Text="{Binding CustomSeparator}"
                                     IsEnabled="{Binding UseCustomSeparator}"
                                     MaxLength="16" Width="120" Height="24"
                                     Margin="8,0,0,0"
                                     ToolTip="Uno o mas caracteres como separador personalizado"/>
                        </DockPanel>
                        <Separator Margin="0,10,0,8"/>
                        <TextBlock Text="Delimitador final de fila:" FontSize="11" Foreground="#5E5E5E" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding RowEndDelimiter}"
                                 Width="120" HorizontalAlignment="Left" Height="24"
                                 MaxLength="8"
                                 ToolTip="Caracter o cadena al final de cada fila, antes del salto de linea. Dejar en blanco para ninguno."/>
                        <TextBlock Text="{Binding SeparatorPreview}"
                                   FontSize="11" Foreground="#5E5E5E" Margin="0,4,0,0" FontStyle="Italic"/>
                    </StackPanel>
                </GroupBox>

                <!-- GroupBox: Filas a exportar -->
                <GroupBox Header="Filas a exportar" Margin="0,0,0,12">
                    <StackPanel Margin="8">
                        <RadioButton Content="Todas las filas" GroupName="RowMode"
                                     IsChecked="{Binding ExportAllRows}" Margin="0,0,0,4"/>
                        <DockPanel Margin="0,4,0,0">
                            <RadioButton Content="Primeras" GroupName="RowMode"
                                         IsChecked="{Binding ExportAllRows, Converter={StaticResource InvertBoolConverter}}"
                                         DockPanel.Dock="Left"/>
                            <TextBox Text="{Binding MaxRows}"
                                     IsEnabled="{Binding ExportAllRows, Converter={StaticResource InvertBoolConverter}}"
                                     Width="64" Height="24" TextAlignment="Right"
                                     Margin="8,0,4,0"
                                     ToolTip="Cantidad de filas a exportar (numero entero positivo)"/>
                            <TextBlock Text="filas" VerticalAlignment="Center" FontSize="13"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>

                <!-- GroupBox: Encabezado -->
                <GroupBox Header="Encabezado" Margin="0,0,0,12">
                    <StackPanel Margin="8">
                        <CheckBox Content="Incluir nombres de columnas en la primera linea"
                                  IsChecked="{Binding IncludeHeader}"/>
                    </StackPanel>
                </GroupBox>

                <!-- GroupBox: Formato numerico -->
                <GroupBox Header="Formato numerico" Margin="0,0,0,12">
                    <StackPanel Margin="8">
                        <TextBlock Text="Separador decimal:" FontSize="11" Foreground="#5E5E5E" Margin="0,0,0,6"/>
                        <RadioButton Content="Coma  (,)" GroupName="DecSep" Margin="0,0,0,2"
                                     IsChecked="{Binding UseCommaDecimal}"/>
                        <RadioButton Content="Punto  (.)" GroupName="DecSep" Margin="0,0,0,2"
                                     IsChecked="{Binding UseDotDecimal}"/>
                    </StackPanel>
                </GroupBox>

                <!-- GroupBox: Codificacion de salida -->
                <GroupBox Header="Codificacion de salida" Margin="0,0,0,12">
                    <StackPanel Margin="8">
                        <TextBlock Text="Codificacion del archivo TXT:" FontSize="11" Foreground="#5E5E5E" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding AvailableOutputEncodings}"
                                  SelectedValue="{Binding OutputEncoding}"
                                  SelectedValuePath="Encoding"
                                  DisplayMemberPath="DisplayName"
                                  Width="200" HorizontalAlignment="Left"
                                  Height="28" FontSize="13"/>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
