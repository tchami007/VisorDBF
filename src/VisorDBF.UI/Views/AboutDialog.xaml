<Window x:Class="VisorDBF.UI.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Acerca de VisorDBF"
        Width="380" Height="280"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFF"
        FontFamily="Segoe UI"
        ShowInTaskbar="False">
    <DockPanel>
        <Button DockPanel.Dock="Bottom"
                Content="Cerrar"
                IsCancel="True"
                Width="88" Height="30"
                HorizontalAlignment="Right"
                Margin="0,0,16,16"
                Style="{StaticResource SecondaryButtonStyle}"/>

        <StackPanel VerticalAlignment="Center" Margin="24,24,24,0">
            <TextBlock Text="VisorDBF"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="#1A1A1A"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>

            <TextBlock x:Name="VersionText"
                       FontSize="12" Foreground="#5E5E5E"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>

            <Separator Margin="0,0,0,16"/>

            <TextBlock Text="Visor, exportacion y traspaso Sybase de archivos DBF"
                       FontSize="11" Foreground="#5E5E5E"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,0,0,16"/>

            <TextBlock x:Name="CopyrightText"
                       FontSize="11" Foreground="#A0A0A0"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </DockPanel>
</Window>
