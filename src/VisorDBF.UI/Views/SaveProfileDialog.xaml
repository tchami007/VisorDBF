<Window x:Class="VisorDBF.UI.Views.SaveProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Guardar perfil"
        Width="350" Height="160"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFF"
        FontFamily="Segoe UI">
    <StackPanel Margin="16">
        <TextBlock Text="Nombre del perfil:" Margin="0,0,0,6"/>
        <TextBox Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}"
                 Height="28" FontSize="14"/>
        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="#E81123"
                   FontSize="11"
                   Margin="0,4,0,0"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="BtnGuardar"
                    Content="Guardar"
                    IsDefault="True"
                    Click="BtnGuardar_Click"
                    Width="80" Height="30"
                    Margin="0,0,8,0"
                    IsEnabled="{Binding CanSave}"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button x:Name="BtnCancelar"
                    Content="Cancelar"
                    IsCancel="True"
                    Click="BtnCancelar_Click"
                    Width="80" Height="30"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>
    </StackPanel>
</Window>
