<Window x:Class="VisorDBF.UI.Views.SybaseConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Conectar a Sybase ASE"
        Width="480" Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFF"
        FontFamily="Segoe UI"
        KeyboardNavigation.TabNavigation="Cycle">

    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="16,8,16,16">
            <Button Content="Probar conexion"
                    Command="{Binding TestConnectionCommand}"
                    IsEnabled="{Binding IsTesting, Converter={StaticResource InvertBoolConverter}}"
                    Width="130" Height="30"
                    Margin="0,0,8,0"
                    Style="{StaticResource SecondaryButtonStyle}"/>
            <Button x:Name="BtnGuardar"
                    Content="Guardar"
                    IsDefault="True"
                    Click="BtnGuardar_Click"
                    Width="88" Height="30"
                    Margin="0,0,8,0"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="Cancelar"
                    IsCancel="True"
                    Width="88" Height="30"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,16,16,0">

                <GroupBox Header="Servidor" Margin="0,0,0,12">
                    <StackPanel Margin="8">
                        <TextBlock Text="Host o direccion IP:" FontSize="11" Foreground="#5E5E5E" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Host}"
                                 Width="280" HorizontalAlignment="Left" Height="24"
                                 ToolTip="Nombre del servidor Sybase o direccion IP"/>
                        <TextBlock Text="Puerto:" FontSize="11" Foreground="#5E5E5E" Margin="0,8,0,4"/>
                        <TextBox Text="{Binding Port}"
                                 Width="100" HorizontalAlignment="Left" Height="24"
                                 ToolTip="Puerto del servidor Sybase (default 5000)"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Base de datos" Margin="0,0,0,12">
                    <StackPanel Margin="8">
                        <TextBlock Text="Nombre de la base:" FontSize="11" Foreground="#5E5E5E" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Database}"
                                 Width="200" HorizontalAlignment="Left" Height="24"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Autenticacion" Margin="0,0,0,12">
                    <StackPanel Margin="8">
                        <TextBlock Text="Usuario:" FontSize="11" Foreground="#5E5E5E" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Username}"
                                 Width="200" HorizontalAlignment="Left" Height="24"/>
                        <TextBlock Text="Contrasena:" FontSize="11" Foreground="#5E5E5E" Margin="0,8,0,4"/>
                        <PasswordBox x:Name="PasswordBox"
                                  Width="200" HorizontalAlignment="Left" Height="24"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Tabla destino" Margin="0,0,0,12">
                    <StackPanel Margin="8">
                        <TextBlock Text="Nombre de la tabla:" FontSize="11" Foreground="#5E5E5E" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding TableName}"
                                 Width="200" HorizontalAlignment="Left" Height="24"
                                 ToolTip="La tabla debe existir en la base de datos y tener columnas con los mismos nombres que los campos DBF"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Columnas adicionales" Margin="0,0,0,12">
                    <StackPanel Margin="8">
                        <TextBlock Text="Agregue columnas que existen en la tabla destino pero no en el archivo DBF:"
                                   FontSize="11" Foreground="#5E5E5E"
                                   TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding ExtraColumns}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                            CornerRadius="4" Padding="6" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="85"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="28"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBox Grid.Column="0"
                                                     Text="{Binding ColumnName, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="Nombre de la columna en Sybase"
                                                     Height="24" Margin="0,0,4,0"/>

                                            <ComboBox Grid.Column="1"
                                                      SelectedIndex="{Binding Type}"
                                                      Height="24" Margin="0,0,4,0">
                                                <ComboBoxItem Content="DateTime"/>
                                                <ComboBoxItem Content="Integer"/>
                                            </ComboBox>

                                            <TextBox Grid.Column="2"
                                                     Text="{Binding RawValue, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="Valor fijo: fecha (2026-01-01) o entero (202601)"
                                                     Height="24" Margin="0,0,4,0"/>

                                            <Button Grid.Column="3"
                                                    Content="✕"
                                                    Width="24" Height="24" Padding="0"
                                                    FontSize="11"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding DataContext.RemoveExtraColumnCommand,
                                                        RelativeSource={RelativeSource AncestorType=GroupBox}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+ Agregar columna"
                                Command="{Binding AddExtraColumnCommand}"
                                Width="140" Height="26"
                                HorizontalAlignment="Left"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Resultado de la prueba" Margin="0,0,12,12">
                    <StackPanel Margin="8">
                        <TextBlock Text="{Binding TestMessage}"
                                   FontSize="11" Margin="0,0,0,4"
                                   Foreground="#5E5E5E">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="(No se ha probado aun)"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTestSuccessful}" Value="True">
                                            <Setter Property="Foreground" Value="#107C10"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsTestSuccessful}" Value="False">
                                            <Setter Property="Foreground" Value="#C42B1C"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding ConnectionString}"
                                   FontSize="10" Foreground="#A0A0A0"
                                   FontFamily="Consolas"/>
                        <Expander Header="Ver detalle tecnico"
                                  IsExpanded="False"
                                  Visibility="{Binding HasDetailedError, Converter={StaticResource BoolToVisibilityConverter}}"
                                  Margin="0,6,0,0">
                            <StackPanel>
                                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding DetailedError}"
                                               FontSize="10"
                                               FontFamily="Consolas"
                                               TextWrapping="Wrap"
                                               Foreground="#5E5E5E"
                                               Margin="0,4,0,0"/>
                                </ScrollViewer>
                                <Button Content="Copiar detalle"
                                        Command="{Binding CopyDetailsCommand}"
                                        Width="110" Height="24"
                                        HorizontalAlignment="Right"
                                        Margin="0,4,0,0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        FontSize="11"
                                        ToolTip="Copia el error completo + connection string al portapapeles"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>