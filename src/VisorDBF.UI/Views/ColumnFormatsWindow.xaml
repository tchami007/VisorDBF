<Window x:Class="VisorDBF.UI.Views.ColumnFormatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Formatos de columna"
        Width="700" Height="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFF"
        FontFamily="Segoe UI"
        KeyboardNavigation.TabNavigation="Cycle">

    <DockPanel>
        <!-- Content area -->
        <Grid DockPanel.Dock="Top" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Configure los formatos de visualizacion para cada columna. Seleccione un formato predefinido o escriba uno personalizado."
                       FontSize="11" Foreground="#5E5E5E" Margin="8,8,0,8"/>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Columns}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="False"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      SelectedItem="{Binding SelectedColumn}"
                      IsSynchronizedWithCurrentItem="True"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#D1D1D1"
                      Background="#FFFFFF"
                      AlternatingRowBackground="#FAFAFA"
                      FontSize="13"
                      RowHeaderWidth="0">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#E8E8E8"/>
                        <Setter Property="BorderBrush" Value="#D1D1D1"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="Padding" Value="4,3,4,3"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="4,2"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#0078D4"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Columna" Binding="{Binding FieldHeader}" IsReadOnly="True" Width="*"/>

                    <DataGridTemplateColumn Header="Formato" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBox Text="{Binding FormatString, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,4,0">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFormattable}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <TextBlock Text="—" VerticalAlignment="Center"
                                               Foreground="#A0A0A0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFormattable}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Activo" Width="64">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsEnabled}"
                                          IsEnabled="{Binding IsFormattable}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Previa" Binding="{Binding PreviewValue}" IsReadOnly="True" Width="160">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsValidFormat}" Value="False">
                                        <Setter Property="Foreground" Value="Red"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="2" Margin="0,8,0,0" Padding="8"
                    Background="#F5F5F5" CornerRadius="4"
                    MinHeight="48">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasSelectedFormattableColumn}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="Formatos predefinidos:" FontSize="11" Foreground="#5E5E5E" Margin="0,0,0,4"/>
                    <ItemsControl ItemsSource="{Binding CurrentPresets}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}"
                                        Command="{Binding DataContext.ApplyPresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Margin="2" Padding="8,2"
                                        FontFamily="Consolas"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Bottom buttons -->
        <Grid DockPanel.Dock="Bottom" Margin="16,8,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="BtnClearAll"
                    Content="Limpiar todo"
                    Command="{Binding ClearAllCommand}"
                    Width="100" Height="30"
                    Style="{StaticResource SecondaryButtonStyle}"/>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button x:Name="BtnAceptar"
                        Content="Aceptar"
                        IsDefault="True"
                        Click="BtnAceptar_Click"
                        Width="88" Height="30"
                        Margin="0,0,8,0"
                        IsEnabled="{Binding HasInvalidFormat, Converter={StaticResource InvertBoolConverter}}"
                        Style="{StaticResource PrimaryButtonStyle}"/>
                <Button x:Name="BtnCancelar"
                        Content="Cancelar"
                        IsCancel="True"
                        Click="BtnCancelar_Click"
                        Width="88" Height="30"
                        Style="{StaticResource SecondaryButtonStyle}"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
